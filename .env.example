# ============================================================================
# Inbox Sales Copilot — Backend Environment Variables
# ⚠️ This file contains real secrets. Never commit it. Never paste it in chat/Slack.
# ============================================================================

# ----- Runtime -----
NODE_ENV=development
PORT=3000

# Comma-separated allowed CORS origins (admin dashboard, Gmail add-on)
CORS_ORIGINS=

# Secret used to sign cookies (min 16 chars). Generate a strong value per env.
COOKIE_SECRET=

# ----- PostgreSQL (pgvector) -----
DATABASE_URL=

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Rate limiting (Redis-backed) -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── AWS S3 Storage ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# ── Google Secrets ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SCOPES=
GOOGLE_PUBSUB_VERIFICATION_TOKEN=
GOOGLE_PUBSUB_TOPIC_NAME=

TOKEN_ENCRYPTION_KEY=
FRONTEND_DASHBOARD_URL=
# FRONTEND_DASHBOARD_URL=http://localhost:5173/callback

# Points SE invite emails at the extension install page (NOT the Chrome Web Store - this extension is deliberately unlisted).
EXTENSION_INSTALL_URL=http://localhost:5173/extension-download

# --- Email Verification (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# API_URL=http://localhost:3000
API_URL=

# --- JWT ---
JWT_SECRET=

# ----- CRM (HubSpot) -----
CRM_PROVIDER=
HUBSPOT_API_KEY=

# ============================================================================
# ----- LLM (AI Phase — Classifier/Extractor/Matcher/Composer/Supervisor) -----
# Provider-agnostic client (openai SDK + baseURL), NOT the Anthropic SDK.
# Currently pointed at Groq (free tier, OpenAI-compatible) while we wait for
# the ITI-sponsored OpenAI key. Swapping providers later = change these 3
# values only, no code change (see llm-client.service.ts).
# ============================================================================

# ── LLM provider (OpenAI-compatible; the team runs Gemini 3.1 Flash Lite) ──
# Comma-separated. 6 keys, each from a DIFFERENT Google account/project
LLM_API_KEYS=
LLM_API_KEY=

# Gemini's OpenAI-compatible endpoint:
#   https://generativelanguage.googleapis.com/v1beta/openai/
# (Groq alternative: https://api.groq.com/openai/v1)
LLM_BASE_URL=

# Portkey Routing configurations
PORTKEY_API_KEY=
PORTKEY_CONFIG_ID=

# Used by generateStructured() — all non-vision agent calls
# (Classifier, Extractor, Matcher, Composer, Supervisor).
# Team standard: gemini-3.1-flash-lite
LLM_MODEL=

# Used by analyzeImage() only — image/attachment understanding.
# ⚠ Shares LLM_API_KEY/LLM_BASE_URL, so it MUST be a model that exists at
# that endpoint. On Gemini use gemini-3.1-flash-lite (it is multimodal).
VISION_MODEL=

# --- Embeddings (separate provider from chat — Groq serves no /embeddings) ---
# Local Ollama, OpenAI-compatible endpoint. Setup:
#   curl -fsSL https://ollama.com/install.sh | sh && ollama pull nomic-embed-text
# The key is ignored by Ollama but the SDK requires a non-empty string.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=ollama

# --- STRIPE Integration ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

#---- LANGSMITH -----
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
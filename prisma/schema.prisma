generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.md"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Client {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  company      String?
  status       String        @default("new_inquiry")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]

  @@map("clients")
}

model Interaction {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date           DateTime @default(now())
  type           String
  subject        String
  aiSummary      String   @map("ai_summary")
  classification String?
  confidence     Float?
  recommendation String?
  createdAt      DateTime @default(now())

  @@map("interactions")
}


model ConnectedAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  scope          String?
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)
  status         String    @default("connected")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  webhookSubscription WebhookSubscription?
  @@map("connected_accounts")
}

model ProcessedGmailMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId    String   @unique @map("message_id")
  threadId     String?  @map("thread_id")
  accountEmail String   @map("account_email")
  processedAt  DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@map("processed_gmail_messages")
}

model WebhookSubscription {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectedAccountId  String    @unique @map("connected_account_id") @db.Uuid
  provider            String    @default("GMAIL")
  expirationDate      DateTime  @map("expiration_date") @db.Timestamptz(6)
  subscriptionId      String?   @map("subscription_id")
  connectedAccount    ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@map("webhook_subscriptions")
}

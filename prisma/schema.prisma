generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.md"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String        @id @default(uuid())
  email        String
  name         String?
  company      String?
  status       String        @default("new_inquiry")
  crmId        String?       @map("crm_id")
  dealId       String?       @map("deal_id")
  tenantId     String?       @map("tenant_id") @db.Uuid
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]

  @@unique([tenantId, email])
  @@map("clients")
}

model Interaction {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  clientId       String   @map("client_id")
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date           DateTime @default(now())
  type           String
  subject        String
  aiSummary      String   @map("ai_summary")
  classification String?
  recommendation String?
  // Which KB document the AI answer was based on ("Based on: X.pdf").
  // Filled by the AI Phase — this column only prepares the slot.
  sourceSnapshot String?  @map("source_snapshot")
  createdAt      DateTime @default(now())
  productConfidence Float?  @map("product_confidence")
  clientHistoryConfidence Float?  @map("client_history_confidence")

  @@map("interactions")
}

model CrmConnection {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @unique @map("tenant_id")
  provider  String
  apiKey    String   @map("api_key")
  status    String   @default("connected")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("crm_connections")
}
model ConnectedAccount {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String
  isAdmin             Boolean              @default(false) @map("is_admin")
  // Admin email+password login (argon2id). Lives on the SAME row as the
  // Google connection so both identities converge — never a duplicate account.
  passwordHash        String?              @map("password_hash")
  accessToken         String               @map("access_token")
  refreshToken        String?              @map("refresh_token")
  scope               String?
  tokenExpiresAt      DateTime?            @map("token_expires_at") @db.Timestamptz(6)
  status              String               @default("connected")
  tenantId            String?              @map("tenant_id") @db.Uuid
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  webhookSubscription WebhookSubscription?

  @@unique([tenantId, email])
  @@map("connected_accounts")
}

model ProcessedGmailMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId    String   @unique @map("message_id")
  threadId     String?  @map("thread_id")
  accountEmail String   @map("account_email")
  processedAt  DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@map("processed_gmail_messages")
}

model WebhookSubscription {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectedAccountId String           @unique @map("connected_account_id") @db.Uuid
  provider           String           @default("GMAIL")
  expirationDate     DateTime         @map("expiration_date") @db.Timestamptz(6)
  subscriptionId     String?          @map("subscription_id")
  // Gmail history baseline: the last historyId the classifier processed for
  // this account. history.list(startHistoryId=this) returns exactly the
  // messages we haven't classified yet. Null until the first watch/notification
  // seeds it.
  lastHistoryId      String?          @map("last_history_id")
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@map("webhook_subscriptions")
}

// Classifier output — "General Analysis". One row per
// Gmail message, written ONCE by the background classifier; every on-demand
// stage (Extractor onward) reads it from here and never re-runs the classifier.
// Keyed by messageId (not Interaction): no Interaction/Client row exists yet
// at webhook time — client identity resolution happens later, on-demand.
model GeneralAnalysis {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId        String   @unique @map("message_id")
  threadId         String?  @map("thread_id")
  accountEmail     String   @map("account_email")
  tenantId         String?  @map("tenant_id") @db.Uuid
  isUrgent         Boolean  @map("is_urgent")
  urgencyReason    String?  @map("urgency_reason")
  intent           String
  intentConfidence Float    @map("intent_confidence")
  reasoning        String?
  promptVersion    String   @map("prompt_version")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, isUrgent])
  @@map("general_analysis")
}

enum DocumentStatus {
  processing
  completed
  failed

  @@map("document_status")
}

model Document {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename        String          @db.VarChar
  productName     String?         @map("product_name") @db.VarChar
  fileType        String?         @map("file_type") @db.VarChar
  status          DocumentStatus  @default(processing)
  chunkCount      Int             @default(0) @map("chunk_count")
  processingError String?         @map("processing_error")
  // Quality gate: flagged at upload time when extraction looks unreliable
  // (e.g. a scanned PDF with almost no extractable text).
  isLowConfidence Boolean         @default(false) @map("is_low_confidence")
  qualityReason   String?         @map("quality_reason")
  uploadedBy      String?         @map("uploaded_by") @db.VarChar
  uploadDate      DateTime        @default(now()) @map("upload_date") @db.Timestamptz(6)
  processedAt     DateTime?       @map("processed_at") @db.Timestamptz(6)
  chunks          DocumentChunk[]
  tenantId        String?         @map("tenant_id") @db.Uuid
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  qualityScore    Int?            @map("quality_score")
  qualityReport   Json?           @map("quality_report")

  @@unique([tenantId, filename, productName], map: "uq_documents_file")
  @@map("documents")
}

model DocumentChunk {
  id         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                       @map("document_id") @db.Uuid
  document   Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int?                         @map("chunk_index")
  content    String?
  embedding  Unsupported("vector(768)")?
  tokenCount Int?                         @map("token_count")
  metadata   Json?

  @@index([documentId], map: "idx_chunks_doc")
  @@map("document_chunks")
}

// US-043 — allow-list gate for the external content resolver (SSRF boundary).
// A domain NOT present here is never fetched. Karim inserts rows directly.
model AllowedDomain {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domain    String
  addedBy   String   @map("added_by")
  tenantId  String?  @map("tenant_id") @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Each tenant maintains its OWN allow-list; two tenants may both allow
  // the same domain without colliding.
  @@unique([tenantId, domain])
  @@map("allowed_domains")
}

// US-043 — single admin-level Google Drive OAuth connection (separate from the
// per-user Gmail connected_accounts). Tokens stored encrypted at rest.
model DriveConnection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  scope          String?
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)
  status         String    @default("connected")
  tenantId       String?   @map("tenant_id") @db.Uuid
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("drive_connections")
}

model KnowledgeGap {
  id          String   @id @default(cuid())
  topic       String
  occurrences Int      @default(1)
  resolved    Boolean  @default(false)
  tenantId    String?  @map("tenant_id") @db.Uuid
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Same topic exists once PER TENANT — occurrence counts never mix
  // between two companies.
  @@unique([tenantId, topic])
  @@map("knowledge_gaps")
}

enum TenantStatus {
  pending
  active
  abandoned
  offboarded

  @@map("tenant_status")
}

model Tenant {
  id                         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName                String       @map("company_name")
  status                     TenantStatus @default(pending)
  tier                       Int          @default(1)
  emailVerifiedAt            DateTime?    @map("email_verified_at")
  emailVerificationToken     String?      @unique @map("email_verification_token")
  emailVerificationExpiresAt DateTime?    @map("email_verification_expires_at")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")

  clients           Client[]
  connectedAccounts ConnectedAccount[]
  documents         Document[]
  allowedDomains    AllowedDomain[]
  driveConnections  DriveConnection[]
  knowledgeGaps     KnowledgeGap[]
  allowlistEntries  AllowlistEntry[]

  @@map("tenants")
}

model AllowlistEntry {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  email      String
  status     String    @default("granted") // granted | verified | revoked
  grantedAt  DateTime  @default(now()) @map("granted_at")
  verifiedAt DateTime? @map("verified_at")
  revokedAt  DateTime? @map("revoked_at")

  @@unique([tenantId, email])
  @@map("allowlist_entries")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.md"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model ConnectedAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  scope          String?
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)
  status         String    @default("connected")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("connected_accounts")
}

model ProcessedGmailMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId    String   @unique @map("message_id")
  threadId     String?  @map("thread_id")
  accountEmail String   @map("account_email")
  processedAt  DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@map("processed_gmail_messages")
}
